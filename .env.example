# Docker runtime
APP_BIND=0.0.0.0
APP_PORT=8787
HOST_PORT=8787
APP_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata
APP_VERSION=0.2.0
CONTAINER_DEPLOYMENT=true

# Persistent paths inside the containers
DATABASE_URL=sqlite:////data/tickets.db
DATA_DIR=/data
SCREENSHOT_DIR=/data/screenshots
LOG_DIR=/data/logs
BACKUP_DIR=/data/backups
CONFIG_DIR=/config

# Telegram notifications. Never commit a real bot token or chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional extra restriction for users issuing commands in allowed groups.
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_STALE_UPDATE_AGE_SECONDS=300

# Session secret for CSRF tokens. install.sh generates this when missing.
SECRET_KEY=

DEFAULT_POLL_INTERVAL_SECONDS=300
MIN_POLL_INTERVAL_SECONDS=120
PLAYWRIGHT_HEADLESS=true
LOG_LEVEL=INFO
SIMULATION_ENABLED=false
SCREENSHOT_RETENTION=50
BACKUP_RETENTION=10
LOG_RETENTION_DAYS=14
PLATFORM_TIMEOUT_SECONDS=30
BLOCKED_RETRY_FIRST_SECONDS=1800
BLOCKED_RETRY_SECOND_SECONDS=3600
BLOCKED_RETRY_SUBSEQUENT_SECONDS=10800
BLOCKED_RETRY_MAX_SECONDS=21600
WORKER_HEARTBEAT_MAX_AGE_SECONDS=90

# Ownership applied only to the two mounted application directories
PUID=1000
PGID=1000

# Optional registry image override
IMAGE_NAME=movie-ticket-watcher
IMAGE_TAG=local
